{
  "name": "@herald-protocol/sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for the Herald Privacy Registry Anchor program",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./user": {
      "types": "./dist/clients/user.d.ts",
      "import": "./dist/clients/user.js",
      "require": "./dist/clients/user.cjs"
    },
    "./authority": {
      "types": "./dist/clients/authority.d.ts",
      "import": "./dist/clients/authority.js",
      "require": "./dist/clients/authority.cjs"
    },
    "./read": {
      "types": "./dist/clients/read.d.ts",
      "import": "./dist/clients/read.js",
      "require": "./dist/clients/read.cjs"
    },
    "./billing": {
      "types": "./dist/billing/index.d.ts",
      "import": "./dist/billing/index.js",
      "require": "./dist/billing/index.cjs"
    },
    "./encryption": {
      "types": "./dist/encryption/index.d.ts",
      "import": "./dist/encryption/index.js",
      "require": "./dist/encryption/index.cjs"
    },
    "./pda": {
      "types": "./dist/pda/index.d.ts",
      "import": "./dist/pda/index.js",
      "require": "./dist/pda/index.cjs"
    },
    "./types": {
      "types": "./dist/types/index.d.ts"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js",
      "require": "./dist/errors/index.cjs"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "import": "./dist/events/index.js",
      "require": "./dist/events/index.cjs"
    },
    "./light": {
      "types": "./dist/light/index.d.ts",
      "import": "./dist/light/index.js",
      "require": "./dist/light/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/**",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run src/__tests__/e2e/integration.e2e.test.ts",
    "clean": "rm -rf dist",
    "publish:manual": "pnpm build && npm publish --access public"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@lightprotocol/stateless.js": "^0.17.1",
    "@sendgrid/mail": "^8.1.6",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.95.4",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "axios": "^1.13.6",
    "bs58": "^6.0.0",
    "ed2curve": "^0.3.0",
    "eventemitter3": "^5.0.1",
    "prom-client": "^15.1.3",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/uuid": "^10.0.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/heraldhq-protocol/herald-sdk-ts.git"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bigint-buffer",
      "bufferutil",
      "esbuild",
      "utf-8-validate"
    ]
  }
}
